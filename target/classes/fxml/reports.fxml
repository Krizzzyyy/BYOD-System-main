<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<BorderPane fx:id="rootPane" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="800.0" prefWidth="1280.0" styleClass="background" stylesheets="@../css/stylesheet.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.reports.ReportsController">

  <top>
    <HBox id="navbar" alignment="CENTER" maxHeight="-Infinity" maxWidth="1.7976931348623157E308" minHeight="-Infinity" minWidth="-Infinity" spacing="10.0" styleClass="navbar">
      <children>
        <ImageView fx:id="logoImage" fitHeight="60.0" fitWidth="60.0" pickOnBounds="true" preserveRatio="true">
          <image><Image url="@../assets/byod-logo.png" /></image>
          <HBox.margin>
            <Insets left="60.0" />
          </HBox.margin>
        </ImageView>
        <Button fx:id="dashboardButton" maxHeight="-Infinity" maxWidth="-Infinity" onAction="#handleDashboard" prefHeight="50.0" styleClass="nav-button" text="Dashboard" />
        <Button fx:id="monitoringButton" maxHeight="-Infinity" maxWidth="-Infinity" onAction="#handleMonitoring" prefHeight="50.0" styleClass="nav-button" text="Monitoring" />
        <Button fx:id="registrationButton" maxHeight="-Infinity" maxWidth="-Infinity" onAction="#handleRegistration" prefHeight="50.0" styleClass="nav-button" text="Registration" />
        <Button fx:id="reportsButton" maxHeight="-Infinity" maxWidth="-Infinity" onAction="#handleReports" prefHeight="50.0" styleClass="nav-button-active" text="Reports" />
        <Region fx:id="spacer" HBox.hgrow="ALWAYS" />
        <Label fx:id="navDateTimeLabel" styleClass="nav-datetime" text="MM/DD/YYYY HH:MM:SS">
          <HBox.margin>
            <Insets right="15.0" />
          </HBox.margin>
        </Label>
        <Button onAction="#handleLogout" styleClass="logout-button" text="⏻ Logout">
          <HBox.margin>
            <Insets right="60.0" />
          </HBox.margin>
        </Button>
      </children>
    </HBox>
  </top>

  <center>
    <StackPane fx:id="viewStack">
        <BorderPane.margin><Insets /></BorderPane.margin>
        <padding><Insets bottom="20.0" left="60.0" right="60.0" top="20.0" /></padding>

      <VBox fx:id="mainView" managed="false" spacing="20" visible="false">

          <VBox VBox.vgrow="NEVER">
            <HBox alignment="CENTER" spacing="10.0" VBox.vgrow="ALWAYS">
              <VBox HBox.hgrow="ALWAYS">
                <Label styleClass="title-2" text="Report &amp; records" />
                <Label styleClass="description" text="Daily/monthly device monitoring reports · History of device entries and edits" />
              </VBox>
              <Region HBox.hgrow="ALWAYS" />
              <Button fx:id="scheduleBtn" onAction="#handleSchedule" styleClass="action-button" text="📅 Schedule" />
              <Button fx:id="exportAllBtn" onAction="#handleExportAll" styleClass="btn-dark" text="⬇ Export all" />
            </HBox>
          </VBox>

          <HBox alignment="CENTER_LEFT" spacing="12">
            <Label styleClass="card-title" text="Period:" />
            <ComboBox fx:id="chartPeriodCombo" maxHeight="-Infinity" minHeight="-Infinity" prefWidth="200.0" styleClass="combo-box" />
            <Region HBox.hgrow="ALWAYS" />
            <Button onAction="#handleRefresh" styleClass="refresh-button" text="↻ Refresh" />
          </HBox>

          <HBox spacing="16">
            <VBox prefWidth="600.0" spacing="4" styleClass="card" HBox.hgrow="ALWAYS">
              <Label fx:id="statTotalStudents" styleClass="card-number" text="2680" />
              <Label styleClass="card-title" text="Admin Controls" />
              <Label styleClass="card-description" text="student BYOD profiles" />
              <Button maxWidth="Infinity" onAction="#handleGenStudents" prefHeight="36" styleClass="btn-dark" text="Open Database" />
            </VBox>
            <VBox prefWidth="600.0" spacing="4" styleClass="card">
              <Label fx:id="statDeviceInventory" styleClass="card-number" text="256" />
              <Label styleClass="card-title" text="Device inventory report" />
              <Label styleClass="card-description" text="Device Summary by Type" wrapText="true" />
              <Button maxWidth="Infinity" onAction="#handleGenInventory" prefHeight="36" styleClass="btn-dark" text="Inventory" />
            </VBox>
            <VBox prefWidth="600.0" spacing="4" styleClass="card" HBox.hgrow="ALWAYS">
              <Label fx:id="statFullExport" styleClass="card-number" text="2313" />
              <Label styleClass="card-title" text="Full data export" />
              <Label styleClass="card-description" text="Export Records (CSV/PDF)" wrapText="true" />
              <Button maxWidth="Infinity" onAction="#handleGenExport" prefHeight="36" styleClass="btn-dark" text="Generate" />
            </VBox>
          </HBox>

        <VBox spacing="12" styleClass="card">
          <Label fx:id="weeklyChartTitle" styleClass="chart-title" text="Ingress-egress by: Daily" />
            <BarChart fx:id="weeklyChart" animated="false" maxHeight="280" prefHeight="280" styleClass="chart">
              <xAxis>
                <CategoryAxis animated="false" side="BOTTOM" />
              </xAxis>
              <yAxis>
                <NumberAxis animated="false" side="LEFT" />
              </yAxis>
            </BarChart>
          </VBox>
        </VBox>

      <VBox fx:id="exportView" managed="false" spacing="20" visible="false">


          <HBox alignment="CENTER_LEFT" spacing="12">
            <Button onAction="#handleBack" prefHeight="40" styleClass="action-button" text="← Back" />
            <VBox spacing="4" HBox.hgrow="ALWAYS">
              <Label styleClass="title-2" text="Report &amp; records" />
              <Label styleClass="description" text="Daily/monthly device monitoring reports · History of device entries and edits" />
            </VBox>
          </HBox>

          <HBox spacing="20" VBox.vgrow="ALWAYS">
            <VBox minWidth="300" prefWidth="380" spacing="14" styleClass="card">
              <Label styleClass="chart-title" text="🔧  Export Parameters" />

              <HBox alignment="CENTER_LEFT" spacing="8">
                <RadioButton fx:id="scopePeriodRadio" onAction="#handleScopeToggle" styleClass="scope-radio" />
                <Label styleClass="form-label-sm" fx:id="scopePeriodLabel" text="PERIOD SCOPE" />
                <Region HBox.hgrow="ALWAYS" />
              </HBox>
              <HBox alignment="CENTER_LEFT" spacing="8" fx:id="periodScopeRow">
                <ComboBox fx:id="exportScopeTypeCombo" prefWidth="120" styleClass="combo-box" promptText="Select..." />
                <ComboBox fx:id="exportScopeValueCombo" prefWidth="160" styleClass="combo-box" promptText="Select..." />
              </HBox>

              <HBox alignment="CENTER_LEFT" spacing="8">
                <RadioButton fx:id="scopeTemporalRadio" onAction="#handleScopeToggle" styleClass="scope-radio" />
                <Label styleClass="form-label-sm" fx:id="scopeTemporalLabel" text="TEMPORAL SCOPE" />
                <Region HBox.hgrow="ALWAYS" />
              </HBox>
              <HBox alignment="CENTER_LEFT" spacing="10" fx:id="temporalScopeRow">
                <DatePicker fx:id="exportFromDate" prefWidth="160" />
                <Label text="—" />
                <DatePicker fx:id="exportToDate" prefWidth="160" />
              </HBox>
              <Label styleClass="form-label-sm" text="STUDENT COURSE" />
              <VBox spacing="6">
                <CheckBox fx:id="exportAllCoursesCheckBox" onAction="#handleSelectAllCourses" styleClass="label-bold" text="All" />
                <GridPane hgap="8" vgap="6">
                  <CheckBox fx:id="exportBSECE" text="BSECE" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                  <CheckBox fx:id="exportBSBAHRM" text="BSBA-HRM" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                  <CheckBox fx:id="exportBSBAMM" text="BSBA-MM" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                  <CheckBox fx:id="exportBSEdEnglish" text="BSEd-English" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                  <CheckBox fx:id="exportBSEdFilipino" text="BSEd-Filipino" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                  <CheckBox fx:id="exportBSEdMath" text="BSEd-Math" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                  <CheckBox fx:id="exportBSIE" text="BSIE" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                  <CheckBox fx:id="exportBSIT" text="BSIT" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                  <CheckBox fx:id="exportBSPSY" text="BSPSY" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                  <CheckBox fx:id="exportBTLEdHE" text="BTLEd-HE" GridPane.columnIndex="1" GridPane.rowIndex="4" />
                  <CheckBox fx:id="exportBSMA" text="BSMA" GridPane.columnIndex="0" GridPane.rowIndex="5" />
                </GridPane>
              </VBox>

              <Label styleClass="form-label-sm" text="ITEM CATEGORY" />
              <VBox spacing="10">
                <CheckBox fx:id="exportAllCheckBox" onAction="#handleSelectAllToggle" styleClass="label-bold" text="All" />
                <CheckBox fx:id="exportDisplayDevices" selected="true" text="Display devices" />
                <CheckBox fx:id="exportAppliances" text="Appliances" />
                <CheckBox fx:id="exportSoundsLight" text="Sounds and light equipment" />
                <CheckBox fx:id="exportProjectPrototypes" text="Other project prototypes" />
                <CheckBox fx:id="exportRentable" text="Rentable items (DDMI)" />
              </VBox>

              <Label styleClass="form-label-sm" text="OUTPUT FORMAT" />
              <HBox spacing="12">
                <VBox alignment="CENTER" spacing="4">
                  <Button fx:id="exportCsvBtn" onAction="#handleExportCsv" prefHeight="60" prefWidth="80" styleClass="format-btn" text="📄" />
                  <Label styleClass="form-label-sm" text="CSV" />
                </VBox>
                <VBox alignment="CENTER" spacing="4">
                  <Button fx:id="exportPdfBtn" onAction="#handleExportPdf" prefHeight="60" prefWidth="80" styleClass="format-btn" text="📕" />
                  <Label styleClass="form-label-sm" text="PDF" />
                </VBox>
                <VBox alignment="CENTER" spacing="4">
                  <Button fx:id="exportXlsBtn" onAction="#handleExportXls" prefHeight="60" prefWidth="80" styleClass="format-btn" text="📊" />
                  <Label styleClass="form-label-sm" text="EXCEL" />
                </VBox>
              </HBox>
              <Button fx:id="generateExportBtn" maxWidth="Infinity" onAction="#handleGenerateExport" prefHeight="46" styleClass="btn-dark" text="☁  Generate secure export" />
            </VBox>

            <VBox spacing="14" styleClass="card" HBox.hgrow="ALWAYS">
              <HBox alignment="CENTER_LEFT" spacing="12">
                <Label styleClass="card-title" text="Recent Exports" />
                <Region HBox.hgrow="ALWAYS" />
                <Button onAction="#handleRefresh" styleClass="refresh-button" text="&#x21BB; Refresh" />
              </HBox>
              <TableView fx:id="exportsTable" prefHeight="400" VBox.vgrow="ALWAYS">
                <columns>
                  <TableColumn fx:id="colExpId" prefWidth="160" text="ID / Timestamp" />
                  <TableColumn fx:id="colExpParams" prefWidth="280" text="Parameters" />
                  <TableColumn fx:id="colExpStatus" prefWidth="120" text="Status" />
                  <TableColumn fx:id="colExpAction" prefWidth="80" text="Action" />
                </columns>
                <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
              </TableView>
            </VBox>
          </HBox>
        </VBox>

      <VBox fx:id="inventoryView" managed="false" spacing="20" visible="false">


          <HBox alignment="CENTER_LEFT" spacing="12">
            <Button onAction="#handleBack" prefHeight="40" styleClass="action-button" text="← Back" />
            <VBox spacing="4" HBox.hgrow="ALWAYS">
              <Label styleClass="title-2" text="Device System Metrics" />
              <Label styleClass="description" text="Hardware deployment distribution analytics across active university terms." />
            </VBox>
          </HBox>

          <HBox alignment="TOP_LEFT" spacing="20">
            <VBox spacing="14" styleClass="card" HBox.hgrow="ALWAYS">
              <Label styleClass="chart-title" text="Device Inventory Report" />
              <Label styleClass="card-description" text="Summary of all the registered devices per student. Categorized by type (laptop, tablet, phone, etc)." wrapText="true" />

              <VBox spacing="14">
                <Label styleClass="chart-title" text="Device Distribution" />
                <Label fx:id="totalDevicesLabel" styleClass="description" text="Total: 0 Devices" />
                <VBox spacing="10">
                  <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label prefWidth="110" styleClass="card-description" text="Laptops" />
                    <ProgressBar fx:id="laptopsBar" prefHeight="16" styleClass="prog-red" HBox.hgrow="ALWAYS" />
                    <Label fx:id="laptopsPct" prefWidth="44" styleClass="card-description" text="0%" />
                  </HBox>
                  <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label prefWidth="110" styleClass="card-description" text="Tablets" />
                    <ProgressBar fx:id="tabletsBar" prefHeight="16" styleClass="prog-gold" HBox.hgrow="ALWAYS" />
                    <Label fx:id="tabletsPct" prefWidth="44" styleClass="card-description" text="0%" />
                  </HBox>
                  <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label prefWidth="110" styleClass="card-description" text="Smartphones" />
                    <ProgressBar fx:id="smartphonesBar" prefHeight="16" styleClass="prog-pink" HBox.hgrow="ALWAYS" />
                    <Label fx:id="smartphonesPct" prefWidth="44" styleClass="card-description" text="0%" />
                  </HBox>
                  <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label prefWidth="110" styleClass="card-description" text="Others" />
                    <ProgressBar fx:id="othersBar" prefHeight="16" styleClass="prog-gray" HBox.hgrow="ALWAYS" />
                    <Label fx:id="othersPct" prefWidth="44" styleClass="card-description" text="0%" />
                  </HBox>
                </VBox>
              </VBox>
            </VBox>

            <VBox prefWidth="280" spacing="12">
              <VBox spacing="8" styleClass="mini-stat-card">
                <Label styleClass="card-description" text="Laptops" />
                <HBox alignment="CENTER_RIGHT" spacing="12">
                  <Label styleClass="emoji-icon" text="💻" />
                  <Label fx:id="laptopsCount" styleClass="card-number" text="0" />
                </HBox>
              </VBox>
              <VBox spacing="8" styleClass="mini-stat-card">
                <Label styleClass="card-description" text="Tablets" />
                <HBox alignment="CENTER_RIGHT" spacing="12">
                  <Label styleClass="emoji-icon" text="📱" />
                  <Label fx:id="tabletsCount" styleClass="card-number" text="0" />
                </HBox>
              </VBox>
              <VBox spacing="8" styleClass="mini-stat-card">
                <Label styleClass="card-description" text="Smartphones" />
                <HBox alignment="CENTER_RIGHT" spacing="12">
                  <Label styleClass="emoji-icon" text="📲" />
                  <Label fx:id="smartphonesCount" styleClass="card-number" text="0" />
                </HBox>
              </VBox>
              <VBox spacing="8" styleClass="mini-stat-card">
                <Label styleClass="card-description" text="Others" />
                <HBox alignment="CENTER_RIGHT" spacing="12">
                  <Label styleClass="emoji-icon" text="💡" />
                  <Label fx:id="othersCount" styleClass="card-number" text="0" />
                </HBox>
              </VBox>
            </VBox>
          </HBox>
        </VBox>

      <VBox fx:id="studentsView" managed="false" spacing="20" visible="false">


          <HBox alignment="CENTER_LEFT" spacing="12">
            <Button onAction="#handleBack" prefHeight="40" styleClass="action-button" text="&#x2190; Back" />
            <VBox spacing="4" HBox.hgrow="ALWAYS">
              <Label styleClass="title-2" text="Report Records Database" />
              <Label styleClass="description" text="View, filter, and manage registered student device records by status and period." />
            </VBox>
            <Region HBox.hgrow="ALWAYS" />
            <Button onAction="#handleRefresh" styleClass="refresh-button" text="&#x21BB; Refresh" />
          </HBox>

          <VBox spacing="14" styleClass="card">
            <Label styleClass="chart-title" text="🛠  Data Modification Entry Form" />
            <HBox alignment="BOTTOM_LEFT" spacing="12">
              <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label styleClass="form-label-sm" text="STUDENT ID" />
                <TextField fx:id="studentIdField" promptText="e.g., 2024-00123-SR-0" />
              </VBox>
              <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label styleClass="form-label-sm" text="FULL NAME" />
                <TextField fx:id="studentNameField" promptText="e.g., Juan Dela Cruz" />
              </VBox>
              <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label styleClass="form-label-sm" text="BRAND / MODEL" />
                <TextField fx:id="serialField" promptText="e.g., Lenovo ThinkPad E14" />
              </VBox>
              <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label styleClass="form-label-sm" text="CONTACT NUMBER" />
                <TextField fx:id="phoneField" promptText="e.g., 09123456789" />
              </VBox>
              <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label styleClass="form-label-sm" text="REMARKS" />
                <TextField fx:id="remarksField" promptText="e.g., For approval" />
              </VBox>
            </HBox>
            <HBox alignment="BOTTOM_LEFT" spacing="12">
              <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label styleClass="form-label-sm" text="DEPARTMENT / COURSE" />
                <ComboBox fx:id="departmentCombo" maxWidth="Infinity" styleClass="combo-box" />
              </VBox>
              <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label styleClass="form-label-sm" text="ITEM CATEGORY" />
                <ComboBox fx:id="deviceCombo" maxWidth="Infinity" styleClass="combo-box" />
              </VBox>
              <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label styleClass="form-label-sm" text="STATUS" />
                <ComboBox fx:id="formStatusCombo" maxWidth="Infinity" styleClass="combo-box" />
              </VBox>
            </HBox>

            <HBox alignment="CENTER_RIGHT" spacing="12">
              <Button onAction="#handleClearForm" styleClass="btn-grey" text="&#x2715; Clear Fields" />
              <Button onAction="#handleOpenTrash" styleClass="btn-grey" text="🗑 Trash Bin" />
              <Button onAction="#handleInsertStudent" styleClass="btn-green" text="➕ Insert Record" />
              <Button onAction="#handleUpdateStudent" styleClass="btn-gold" text="✏ Update Selected" />
              <Button onAction="#handleDeleteStudent" styleClass="btn-red" text="🗑 Move to Trash" />
            </HBox>
          </VBox>

          <VBox spacing="12" styleClass="card">
            <HBox alignment="CENTER_LEFT" spacing="12">
              <Label styleClass="card-title" text="Active Live Records Database" />
              <Region HBox.hgrow="ALWAYS" />
              <Label fx:id="filteredCountLabel" styleClass="form-label-sm" text="0 record(s) found" />
              <Label styleClass="form-label-sm" text="PERIOD:" />
              <ComboBox fx:id="statusPeriodCombo" maxWidth="180" prefWidth="160" styleClass="combo-box" />
              <Label styleClass="form-label-sm" text="STATUS:" />
              <ComboBox fx:id="statusFilterCombo" maxWidth="180" prefWidth="160" styleClass="combo-box" />
            </HBox>
            <TableView fx:id="studentsTable" VBox.vgrow="ALWAYS">
              <columns>
                <TableColumn fx:id="colUserCategory" prefWidth="130" text="User Category" />
                <TableColumn fx:id="colStudentId" prefWidth="130" text="Student ID" />
                <TableColumn fx:id="colName" prefWidth="180" text="Student Name" />
                <TableColumn fx:id="colDepartment" prefWidth="180" text="Department" />
                <TableColumn fx:id="colDevice" prefWidth="140" text="Registered Devices" />
                <TableColumn fx:id="colSerial" prefWidth="150" text="Brand / Model" />
                <TableColumn fx:id="colPhone" prefWidth="120" text="Contact Number" />
                <TableColumn fx:id="colRemarks" prefWidth="180" text="Remarks" />
                <TableColumn fx:id="colStatus" prefWidth="100" text="Status" />
              </columns>
              <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
            </TableView>
          </VBox>
        </VBox>

      <VBox fx:id="trashView" managed="false" spacing="20" visible="false">


          <HBox alignment="CENTER_LEFT" spacing="12">
            <Button onAction="#handleBackToStudents" prefHeight="40" styleClass="action-button" text="← Back to Students" />
            <VBox spacing="4" HBox.hgrow="ALWAYS">
              <Label styleClass="title-2" text="🗑 Trash Bin" />
              <Label fx:id="trashCountLabel" styleClass="description" text="0 record(s) in trash" />
            </VBox>
          </HBox>

          <Label styleClass="description" text="Soft-deleted records are stored here. You can restore them or permanently delete them." />

          <VBox spacing="12" styleClass="card">
            <HBox alignment="CENTER_RIGHT" spacing="12">
              <Button onAction="#handleRestoreStudent" styleClass="btn-green" text="♻ Restore Selected" />
              <Button onAction="#handlePermanentDelete" styleClass="btn-red" text="⚠ Permanently Delete" />
              <Button onAction="#handleEmptyTrash" styleClass="btn-dark-red" text="🗑 Empty Trash" />
            </HBox>
            <TableView fx:id="trashTable" prefHeight="400" VBox.vgrow="ALWAYS">
              <columns>
                <TableColumn fx:id="trColUserCategory" prefWidth="130" text="User Category" />
                <TableColumn fx:id="trColStudentId" prefWidth="130" text="Student ID" />
                <TableColumn fx:id="trColName" prefWidth="200" text="Student Name" />
                <TableColumn fx:id="trColDepartment" prefWidth="220" text="Department" />
                <TableColumn fx:id="trColDevice" prefWidth="160" text="Registered Devices" />
                <TableColumn fx:id="trColSerial" prefWidth="180" text="Brand / Model" />
                <TableColumn fx:id="trColPhone" prefWidth="150" text="Contact Number" />
              </columns>
              <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
            </TableView>
          </VBox>
        </VBox>

    </StackPane>
  </center>
</BorderPane>
