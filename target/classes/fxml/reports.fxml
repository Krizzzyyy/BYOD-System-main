<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<BorderPane fx:id="rootPane" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="800.0" prefWidth="1280.0" styleClass="background" stylesheets="@../css/stylesheet.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.reports.ReportsController">

  <top>
    <HBox id="navbar" alignment="CENTER" maxHeight="-Infinity" maxWidth="1.7976931348623157E308" minHeight="-Infinity" minWidth="-Infinity" spacing="10.0" styleClass="navbar" BorderPane.alignment="CENTER">
      <children>
        <ImageView fx:id="logoImage" fitHeight="60.0" fitWidth="60.0" pickOnBounds="true" preserveRatio="true">
          <image><Image url="@../assets/byod-logo.png" /></image>
          <HBox.margin>
            <Insets left="60.0" />
          </HBox.margin>
        </ImageView>
        <Button fx:id="dashboardButton" maxHeight="-Infinity" maxWidth="-Infinity" mnemonicParsing="false" onAction="#handleDashboard" prefHeight="50.0" styleClass="nav-button" text="Dashboard" />
        <Button fx:id="monitoringButton" maxHeight="-Infinity" maxWidth="-Infinity" mnemonicParsing="false" onAction="#handleMonitoring" prefHeight="50.0" styleClass="nav-button" text="Monitoring" />
        <Button fx:id="registrationButton" maxHeight="-Infinity" maxWidth="-Infinity" mnemonicParsing="false" onAction="#handleRegistration" prefHeight="50.0" styleClass="nav-button" text="Registration" />
        <Button fx:id="reportsButton" maxHeight="-Infinity" maxWidth="-Infinity" mnemonicParsing="false" onAction="#handleReports" prefHeight="50.0" styleClass="nav-button-active" text="Reports" />
        <Region fx:id="spacer" HBox.hgrow="ALWAYS" />
        <Label fx:id="navDateTimeLabel" styleClass="nav-datetime" text="MM/DD/YYYY HH:MM:SS">
          <HBox.margin>
            <Insets right="15.0" />
          </HBox.margin>
        </Label>
        <Button onAction="#handleLogout" styleClass="logout-button" text="⏻ Logout">
          <HBox.margin>
            <Insets right="60.0" />
          </HBox.margin>
        </Button>
      </children>
    </HBox>
  </top>

  <center>
    <StackPane fx:id="viewStack">
        <BorderPane.margin><Insets /></BorderPane.margin>
        <padding><Insets bottom="20.0" left="60.0" right="60.0" top="20.0" /></padding>

      <VBox fx:id="mainView" managed="false" spacing="20" visible="false">

          <VBox VBox.vgrow="NEVER">
            <HBox alignment="CENTER" spacing="10.0" VBox.vgrow="ALWAYS">
              <VBox HBox.hgrow="ALWAYS">
                <Label styleClass="title-2" text="Report &amp; records" />
                <Label styleClass="description" text="Daily/monthly device monitoring reports · History of device entries and edits" />
              </VBox>
              <Region HBox.hgrow="ALWAYS" />
              <Button fx:id="scheduleBtn" onAction="#handleSchedule" styleClass="action-button" text="📅 Schedule" />
              <Button fx:id="exportAllBtn" onAction="#handleExportAll" styleClass="btn-dark" text="⬇ Export all" />
            </HBox>
          </VBox>

          <HBox alignment="CENTER_LEFT" spacing="12">
            <Label styleClass="card-title" text="Period:" />
            <ComboBox fx:id="chartPeriodCombo" maxHeight="-Infinity" minHeight="-Infinity" prefWidth="200.0" styleClass="combo-box" />
            <Region HBox.hgrow="ALWAYS" />
            <Button onAction="#handleRefresh" styleClass="refresh-button" text="↻ Refresh" />
          </HBox>

          <HBox spacing="16">
            <VBox prefWidth="600.0" spacing="4" styleClass="card" HBox.hgrow="ALWAYS">
              <Label fx:id="statTotalStudents" styleClass="card-number" text="2680" />
              <Label styleClass="card-title" text="Admin Controls" />
              <Label styleClass="card-description" text="student BYOD profiles" />
              <Button maxWidth="Infinity" onAction="#handleGenStudents" prefHeight="36" styleClass="btn-dark" text="Open Database" />
            </VBox>
            <VBox prefWidth="600.0" spacing="4" styleClass="card">
              <Label fx:id="statDeviceInventory" styleClass="card-number" text="256" />
              <Label styleClass="card-title" text="Device inventory report" />
              <Label styleClass="card-description" text="Device Summary by Type" wrapText="true" />
              <Button maxWidth="Infinity" onAction="#handleGenInventory" prefHeight="36" styleClass="btn-dark" text="Inventory" />
            </VBox>
            <VBox prefWidth="600.0" spacing="4" styleClass="card" HBox.hgrow="ALWAYS">
              <Label fx:id="statFullExport" styleClass="card-number" text="2313" />
              <Label styleClass="card-title" text="Full data export" />
              <Label styleClass="card-description" text="Export Records (CSV/PDF)" wrapText="true" />
              <Button maxWidth="Infinity" onAction="#handleGenExport" prefHeight="36" styleClass="btn-dark" text="Generate" />
            </VBox>
          </HBox>

        <VBox spacing="12" styleClass="card">
          <Label fx:id="weeklyChartTitle" styleClass="chart-title" text="Ingress-egress by: Daily" />
            <BarChart fx:id="weeklyChart" animated="false" maxHeight="280" prefHeight="280" styleClass="chart">
              <xAxis>
                <CategoryAxis animated="false" side="BOTTOM" />
              </xAxis>
              <yAxis>
                <NumberAxis animated="false" side="LEFT" />
              </yAxis>
            </BarChart>
          </VBox>
        </VBox>

      <VBox fx:id="exportView" managed="false" spacing="20" visible="false">


          <VBox VBox.vgrow="NEVER">
            <HBox alignment="CENTER_LEFT" spacing="12">
              <Button onAction="#handleBack" prefHeight="40" styleClass="action-button" text="&#x2190; Back" />
              <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label styleClass="title-2" text="Report &amp; records" />
                <Label styleClass="description" text="Daily/monthly device monitoring reports · History of device entries and edits" />
              </VBox>
            </HBox>
          </VBox>

        <HBox spacing="20" VBox.vgrow="ALWAYS">
          <VBox spacing="10" styleClass="card" minWidth="300" prefWidth="380">
            <Label styleClass="chart-title" text="&#x1F527;  Export Parameters" />

              <HBox alignment="CENTER_LEFT" spacing="6">
                <RadioButton fx:id="scopePeriodRadio" onAction="#handleScopeToggle" styleClass="scope-radio" />
                <Label styleClass="form-label-sm" fx:id="scopePeriodLabel" text="PERIOD SCOPE" />
                <Region HBox.hgrow="ALWAYS" />
              </HBox>
              <HBox alignment="CENTER_LEFT" spacing="6" fx:id="periodScopeRow">
                <ComboBox fx:id="exportScopeTypeCombo" styleClass="combo-box" promptText="Select..." />
                <ComboBox fx:id="exportScopeValueCombo" styleClass="combo-box" promptText="Select..." disable="true" />
              </HBox>

              <HBox alignment="CENTER_LEFT" spacing="6">
                <RadioButton fx:id="scopeTemporalRadio" onAction="#handleScopeToggle" styleClass="scope-radio" />
                <Label styleClass="form-label-sm" fx:id="scopeTemporalLabel" text="TEMPORAL SCOPE" />
                <Region HBox.hgrow="ALWAYS" />
              </HBox>
              <HBox alignment="CENTER_LEFT" spacing="6" fx:id="temporalScopeRow">
                <DatePicker fx:id="exportFromDate" />
                <Label text="—" />
                <DatePicker fx:id="exportToDate" />
              </HBox>
              <Label styleClass="form-label-sm" text="USER CATEGORY" />
              <HBox spacing="10" alignment="CENTER_LEFT">
                <CheckBox fx:id="exportAllCategoriesCheckBox" onAction="#handleSelectAllCategories" styleClass="label-bold" text="All" />
                <CheckBox fx:id="exportStudent" text="Student" />
                <CheckBox fx:id="exportStaff" text="Staff" />
                <CheckBox fx:id="exportGuest" text="Guest" />
              </HBox>

              <Label styleClass="form-label-sm" text="ITEM CATEGORY" />
              <VBox spacing="4">
                <CheckBox fx:id="exportAllCheckBox" onAction="#handleSelectAllToggle" styleClass="label-bold" text="All" />
                <CheckBox fx:id="exportDisplayDevices" selected="true" text="Display devices" />
                <CheckBox fx:id="exportAppliances" text="Appliances" />
                <CheckBox fx:id="exportSoundsLight" text="Sounds and light equipment" />
                <CheckBox fx:id="exportProjectPrototypes" text="Other project prototypes" />
                <CheckBox fx:id="exportRentable" text="Rentable items (DDMI)" />
              </VBox>

              <Label styleClass="form-label-sm" text="OUTPUT FORMAT" />
              <HBox spacing="10" alignment="CENTER">
                <VBox alignment="CENTER" spacing="2" HBox.hgrow="ALWAYS">
                  <Button fx:id="exportCsvBtn" onAction="#handleExportCsv" maxWidth="Infinity" prefHeight="50" styleClass="format-btn" text="&#x1F4C4;" />
                  <Label styleClass="form-label-sm" text="CSV" />
                </VBox>
                <VBox alignment="CENTER" spacing="2" HBox.hgrow="ALWAYS">
                  <Button fx:id="exportPdfBtn" onAction="#handleExportPdf" maxWidth="Infinity" prefHeight="50" styleClass="format-btn" text="&#x1F4D5;" />
                  <Label styleClass="form-label-sm" text="PDF" />
                </VBox>
                <VBox alignment="CENTER" spacing="2" HBox.hgrow="ALWAYS">
                  <Button fx:id="exportXlsBtn" onAction="#handleExportXls" maxWidth="Infinity" prefHeight="50" styleClass="format-btn" text="&#x1F4CA;" />
                  <Label styleClass="form-label-sm" text="EXCEL" />
                </VBox>
              </HBox>
            <Button fx:id="generateExportBtn" maxWidth="Infinity" onAction="#handleGenerateExport" prefHeight="48" styleClass="btn-dark" text="&#x2601;  Generate secure export" />
          </VBox>

          <VBox spacing="14" styleClass="card" HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT" spacing="12">
              <Label styleClass="card-title" text="Recent Exports" />
                <Region HBox.hgrow="ALWAYS" />
                <Button onAction="#handleRefresh" styleClass="refresh-button" text="&#x21BB; Refresh" />
              </HBox>
              <TableView fx:id="exportsTable" prefHeight="400" VBox.vgrow="ALWAYS">
                <columns>
                  <TableColumn fx:id="colExpId" prefWidth="160" text="ID / Timestamp" />
                  <TableColumn fx:id="colExpParams" prefWidth="280" text="Parameters" />
                  <TableColumn fx:id="colExpStatus" prefWidth="120" text="Status" />
                  <TableColumn fx:id="colExpAction" prefWidth="80" text="Action" />
                </columns>
                <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
              </TableView>
            </VBox>
          </HBox>
        </VBox>

      <VBox fx:id="inventoryView" managed="false" spacing="20" visible="false">


          <VBox VBox.vgrow="NEVER">
            <HBox alignment="CENTER_LEFT" spacing="12">
              <Button onAction="#handleBack" prefHeight="40" styleClass="action-button" text="&#x2190; Back" />
              <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label styleClass="title-2" text="Device System Metrics" />
                <Label styleClass="description" text="Hardware deployment distribution analytics across active university terms." />
              </VBox>
            </HBox>
          </VBox>

          <HBox alignment="TOP_LEFT" spacing="20">
            <VBox spacing="14" styleClass="card" HBox.hgrow="ALWAYS">
              <Label styleClass="chart-title" text="Device Inventory Report" />
              <Label styleClass="card-description" text="Summary of all the registered devices per student. Categorized by type (laptop, tablet, phone, etc)." wrapText="true" />

              <VBox spacing="14">
                <Label styleClass="chart-title" text="Device Distribution" />
                <Label fx:id="totalDevicesLabel" styleClass="description" text="Total: 0 Devices" />
                <VBox spacing="10">
                  <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label prefWidth="160" styleClass="card-description" text="Display devices" />
                    <ProgressBar fx:id="displayDevicesBar" prefHeight="16" styleClass="prog-red" HBox.hgrow="ALWAYS" />
                    <Label fx:id="displayDevicesPct" prefWidth="44" styleClass="card-description" text="0%" />
                  </HBox>
                  <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label prefWidth="160" styleClass="card-description" text="Appliances" />
                    <ProgressBar fx:id="appliancesBar" prefHeight="16" styleClass="prog-gold" HBox.hgrow="ALWAYS" />
                    <Label fx:id="appliancesPct" prefWidth="44" styleClass="card-description" text="0%" />
                  </HBox>
                  <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label prefWidth="160" styleClass="card-description" text="Sounds and light equip." />
                    <ProgressBar fx:id="soundsLightBar" prefHeight="16" styleClass="prog-pink" HBox.hgrow="ALWAYS" />
                    <Label fx:id="soundsLightPct" prefWidth="44" styleClass="card-description" text="0%" />
                  </HBox>
                  <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label prefWidth="160" styleClass="card-description" text="Other project prototypes" />
                    <ProgressBar fx:id="projectPrototypesBar" prefHeight="16" styleClass="prog-gray" HBox.hgrow="ALWAYS" />
                    <Label fx:id="projectPrototypesPct" prefWidth="44" styleClass="card-description" text="0%" />
                  </HBox>
                  <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label prefWidth="160" styleClass="card-description" text="Rentable items (DDMI)" />
                    <ProgressBar fx:id="rentableBar" prefHeight="16" styleClass="prog-blue" HBox.hgrow="ALWAYS" />
                    <Label fx:id="rentablePct" prefWidth="44" styleClass="card-description" text="0%" />
                  </HBox>
                </VBox>
              </VBox>
            </VBox>

            <VBox prefWidth="280" spacing="12">
              <VBox spacing="8" styleClass="mini-stat-card">
                <Label styleClass="card-description" text="Display devices" />
                <HBox alignment="CENTER_RIGHT" spacing="12">
                  <Label styleClass="emoji-icon" text="🖥" />
                  <Label fx:id="displayDevicesCount" styleClass="card-number" text="0" />
                </HBox>
              </VBox>
              <VBox spacing="8" styleClass="mini-stat-card">
                <Label styleClass="card-description" text="Appliances" />
                <HBox alignment="CENTER_RIGHT" spacing="12">
                  <Label styleClass="emoji-icon" text="🔌" />
                  <Label fx:id="appliancesCount" styleClass="card-number" text="0" />
                </HBox>
              </VBox>
              <VBox spacing="8" styleClass="mini-stat-card">
                <Label styleClass="card-description" text="Sounds and light" />
                <HBox alignment="CENTER_RIGHT" spacing="12">
                  <Label styleClass="emoji-icon" text="🔊" />
                  <Label fx:id="soundsLightCount" styleClass="card-number" text="0" />
                </HBox>
              </VBox>
              <VBox spacing="8" styleClass="mini-stat-card">
                <Label styleClass="card-description" text="Project prototypes" />
                <HBox alignment="CENTER_RIGHT" spacing="12">
                  <Label styleClass="emoji-icon" text="🧪" />
                  <Label fx:id="projectPrototypesCount" styleClass="card-number" text="0" />
                </HBox>
              </VBox>
              <VBox spacing="8" styleClass="mini-stat-card">
                <Label styleClass="card-description" text="Rentable items" />
                <HBox alignment="CENTER_RIGHT" spacing="12">
                  <Label styleClass="emoji-icon" text="📦" />
                  <Label fx:id="rentableCount" styleClass="card-number" text="0" />
                </HBox>
              </VBox>
            </VBox>
          </HBox>
        </VBox>

      <VBox fx:id="studentsView" managed="false" spacing="20" visible="false">

          <VBox VBox.vgrow="NEVER">
            <HBox alignment="CENTER_LEFT" spacing="12">
              <Button onAction="#handleBack" prefHeight="40" styleClass="action-button" text="&#x2190; Back" />
              <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label styleClass="title-2" text="Report Records Database" />
                <Label styleClass="description" text="View, filter, and manage registered student device records by status and period." />
              </VBox>
              <Region HBox.hgrow="ALWAYS" />
              <Button onAction="#handleOpenTrash" styleClass="btn-grey" text="&#x1F5D1; Trash Bin" />
              <Button onAction="#handleRefresh" styleClass="refresh-button" text="&#x21BB; Refresh" />
            </HBox>
          </VBox>

        <ScrollPane styleClass="scroll-bg" fitToWidth="true" VBox.vgrow="ALWAYS">
          <VBox spacing="20">
            <VBox spacing="10" styleClass="card">
              <Label styleClass="chart-title" text="&#x1F6E0;  Data Modification Entry Form" />
              <GridPane hgap="8" vgap="6">
                <columnConstraints>
                  <ColumnConstraints minWidth="140" prefWidth="180" hgrow="ALWAYS" />
                  <ColumnConstraints minWidth="130" prefWidth="150" hgrow="ALWAYS" />
                  <ColumnConstraints minWidth="120" prefWidth="140" hgrow="ALWAYS" />
                  <ColumnConstraints minWidth="110" prefWidth="130" hgrow="ALWAYS" />
                  <ColumnConstraints minWidth="100" prefWidth="120" hgrow="ALWAYS" />
                </columnConstraints>
                <!-- Row 0: Personal Identity -->
                <VBox spacing="3" GridPane.columnIndex="0" GridPane.rowIndex="0">
                  <Label styleClass="form-label-sm" text="FULL NAME" />
                  <TextField fx:id="studentNameField" promptText="e.g., Juan Dela Cruz" />
                </VBox>
                <VBox spacing="3" GridPane.columnIndex="1" GridPane.rowIndex="0">
                  <Label styleClass="form-label-sm" text="STUDENT ID" />
                  <TextField fx:id="studentIdField" promptText="e.g., 2024-00123-SR-0" />
                </VBox>
                <VBox spacing="3" GridPane.columnIndex="2" GridPane.rowIndex="0">
                  <Label styleClass="form-label-sm" text="CONTACT NO." />
                  <TextField fx:id="phoneField" promptText="e.g., 09123456789" />
                </VBox>
                <VBox spacing="3" GridPane.columnIndex="3" GridPane.rowIndex="0">
                  <Label styleClass="form-label-sm" text="USER CATEGORY" />
                  <ComboBox fx:id="userCategoryCombo" maxWidth="Infinity" styleClass="combo-box" />
                </VBox>
                <VBox spacing="3" GridPane.columnIndex="4" GridPane.rowIndex="0">
                  <Label styleClass="form-label-sm" text="PROGRAM / COURSE" />
                  <ComboBox fx:id="departmentCombo" maxWidth="Infinity" styleClass="combo-box" />
                </VBox>
                <!-- Row 1: Academic & Device -->
                <VBox spacing="3" GridPane.columnIndex="0" GridPane.rowIndex="1">
                  <Label styleClass="form-label-sm" text="YEAR &amp; SEC" />
                  <TextField fx:id="yearSectionField" promptText="e.g., 3-A" />
                </VBox>
                <VBox spacing="3" GridPane.columnIndex="1" GridPane.rowIndex="1">
                  <Label styleClass="form-label-sm" text="ITEM CATEGORY" />
                  <ComboBox fx:id="deviceCombo" maxWidth="Infinity" styleClass="combo-box" />
                </VBox>
                <VBox spacing="3" GridPane.columnIndex="2" GridPane.rowIndex="1">
                  <Label styleClass="form-label-sm" text="FORM ID" />
                  <TextField fx:id="formIdField" promptText="Auto-generated" editable="false" />
                </VBox>
                <VBox spacing="3" GridPane.columnIndex="3" GridPane.rowIndex="1">
                  <Label styleClass="form-label-sm" text="BRAND / MODEL" />
                  <TextField fx:id="serialField" promptText="e.g., Lenovo ThinkPad E14" />
                </VBox>
                <VBox spacing="3" GridPane.columnIndex="4" GridPane.rowIndex="1">
                  <Label styleClass="form-label-sm" text="COLOR / DESC" />
                  <TextField fx:id="colorDescField" promptText="e.g., Black" />
                </VBox>
              </GridPane>
              <HBox spacing="8" alignment="CENTER_LEFT">
                <Label styleClass="form-label-sm" text="ENTRY DATE" />
                <DatePicker fx:id="entryDatePicker" maxWidth="Infinity" />
                <Label styleClass="form-label-sm" text="STATUS" />
                <ComboBox fx:id="formStatusCombo" maxWidth="Infinity" styleClass="combo-box" />
                <Label styleClass="form-label-sm" text="REMARKS" />
                <TextField fx:id="remarksField" promptText="e.g., For approval" HBox.hgrow="ALWAYS" />
              </HBox>
              <HBox alignment="CENTER_RIGHT" spacing="10">
                <Button onAction="#handleClearForm" styleClass="btn-grey" text="&#x2715; Clear Fields" />
                <Button onAction="#handleUpdateStudent" styleClass="btn-gold" text="&#x270F; Update Selected" />
                <Button onAction="#handleDeleteStudent" styleClass="btn-red" text="&#x1F5D1; Move to Trash" />
              </HBox>
            </VBox>

            <VBox spacing="10" styleClass="card">
              <HBox alignment="CENTER_LEFT" spacing="12">
                <Label styleClass="card-title" text="Active Live Records Database" />
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="filteredCountLabel" styleClass="form-label-sm" text="0 record(s) found" />
                <Label styleClass="form-label-sm" text="PERIOD:" />
                <ComboBox fx:id="statusPeriodCombo" maxWidth="180" prefWidth="160" styleClass="combo-box" />
                <Label styleClass="form-label-sm" text="STATUS:" />
                <ComboBox fx:id="statusFilterCombo" maxWidth="180" prefWidth="160" styleClass="combo-box" />
              </HBox>
              <TableView fx:id="studentsTable" prefHeight="450" VBox.vgrow="ALWAYS">
                <columns>
                  <TableColumn fx:id="colFormId" prefWidth="150" text="Form ID" />
                  <TableColumn fx:id="colName" prefWidth="180" text="Full Name" />
                  <TableColumn fx:id="colUserCategory" prefWidth="120" text="User Category" />
                  <TableColumn fx:id="colStudentId" prefWidth="130" text="Student ID" />
                  <TableColumn fx:id="colDepartment" prefWidth="180" text="Program/Course" />
                  <TableColumn fx:id="colYearSection" prefWidth="130" text="Year and Section" />
                  <TableColumn fx:id="colPhone" prefWidth="130" text="Contact Number" />
                  <TableColumn fx:id="colDevice" prefWidth="140" text="Item Category" />
                  <TableColumn fx:id="colSerial" prefWidth="150" text="Brand/Model" />
                  <TableColumn fx:id="colColorDesc" prefWidth="150" text="Color/Description" />
                  <TableColumn fx:id="colEntryDate" prefWidth="120" text="Entry Date" />
                  <TableColumn fx:id="colStatus" prefWidth="100" text="Status" />
                  <TableColumn fx:id="colRemarks" prefWidth="180" text="Remarks" />
                </columns>
                <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
              </TableView>
            </VBox>
          </VBox>
        </ScrollPane>
      </VBox>

      <VBox fx:id="trashView" managed="false" spacing="20" visible="false">


          <VBox VBox.vgrow="NEVER">
            <HBox alignment="CENTER_LEFT" spacing="12">
              <Button onAction="#handleBackToStudents" prefHeight="40" styleClass="action-button" text="&#x2190; Back to Students" />
              <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label styleClass="title-2" text="&#x1F5D1; Trash Bin" />
                <Label fx:id="trashCountLabel" styleClass="description" text="0 record(s) in trash" />
              </VBox>
            </HBox>
          </VBox>

          <Label styleClass="description" text="Soft-deleted records are stored here. You can restore them or permanently delete them." />

          <VBox spacing="12" styleClass="card">
            <HBox alignment="CENTER_RIGHT" spacing="12">
              <Button onAction="#handleRestoreStudent" styleClass="btn-green" text="♻ Restore Selected" />
              <Button onAction="#handlePermanentDelete" styleClass="btn-red" text="⚠ Permanently Delete" />
              <Button onAction="#handleEmptyTrash" styleClass="btn-dark-red" text="🗑 Empty Trash" />
            </HBox>
            <TableView fx:id="trashTable" prefHeight="400" VBox.vgrow="ALWAYS">
              <columns>
                <TableColumn fx:id="trColFormId" prefWidth="150" text="Form ID" />
                <TableColumn fx:id="trColName" prefWidth="180" text="Full Name" />
                <TableColumn fx:id="trColUserCategory" prefWidth="120" text="User Category" />
                <TableColumn fx:id="trColStudentId" prefWidth="130" text="Student ID" />
                <TableColumn fx:id="trColDepartment" prefWidth="180" text="Program/Course" />
                <TableColumn fx:id="trColYearSection" prefWidth="130" text="Year and Section" />
                <TableColumn fx:id="trColPhone" prefWidth="130" text="Contact Number" />
                <TableColumn fx:id="trColDevice" prefWidth="140" text="Item Category" />
                <TableColumn fx:id="trColSerial" prefWidth="150" text="Brand/Model" />
                <TableColumn fx:id="trColColorDesc" prefWidth="150" text="Color/Description" />
                <TableColumn fx:id="trColEntryDate" prefWidth="120" text="Entry Date" />
